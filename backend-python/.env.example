# ScholarAI Python AI Service Configuration

# 基础配置
APP_NAME=ScholarAI AI Service
DEBUG=false
LOG_LEVEL=info

# PostgreSQL 数据库
DATABASE_URL=postgresql://scholarai:scholarai123@localhost:5432/scholarai

# Redis 缓存
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Neo4j 图数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=scholarai123

# Milvus 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_IMAGES=paper_images
MILVUS_COLLECTION_TABLES=paper_tables
MILVUS_COLLECTION_CONTENTS=paper_contents
MILVUS_POOL_SIZE=10
MILVUS_TIMEOUT=10

# API 密钥 (需要配置)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 智谱 AI API (需要配置)
ZHIPU_API_KEY=
ZHIPU_MODEL_VISION=glm-4v
ZHIPU_MODEL_TEXT=glm-4-flash
ZHIPU_MAX_TOKENS=150
ZHIPU_TEMPERATURE=0.3

# ZhipuAI GLM-4.5-Air Configuration
LLM_MODEL=glm-4.5-air
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4

# 默认模型配置
DEFAULT_MODEL=glm-4.5-air

# 文件上传
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/app/papers

# 对象存储配置
OSS_ENDPOINT=local
LOCAL_STORAGE_PATH=/app/uploads

# RAG 配置
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=10

# CORS
ALLOWED_HOSTS=["*"]

# HuggingFace Offline Mode (use cached models)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ========================================
# 新模型配置 (Phase 18 - 2025-04-05)
# ========================================

# Embedding 模型 (使用 Qwen3-VL-Embedding-2B)
EMBEDDING_MODEL=qwen3-vl-2b
EMBEDDING_QUANTIZATION=int4
EMBEDDING_DIMENSION=2048
EMBEDDING_DEVICE=auto  # auto | cpu | cuda | mps (per D-19: auto-detect GPU)

# Reranker 模型 (使用 Qwen3-VL-Reranker-2B)
RERANKER_MODEL=qwen3-vl-reranker
RERANKER_QUANTIZATION=fp16

# 本地模型路径
QWEN3VL_EMBEDDING_MODEL_PATH=./Qwen/Qwen3-VL-Embedding-2B
QWEN3VL_RERANKER_MODEL_PATH=./Qwen3-VL-Reranker-2B