{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@scholar-ai/types": ["../types/src/index.ts"],
      "@scholar-ai/types/*": ["../types/src/*"]
    }
  },
  "include": ["src"]
}