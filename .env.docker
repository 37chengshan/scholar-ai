# ScholarAI 容器内通信配置 (Docker 服务名)
# 用于: 容器间通信 (backend, celery_worker, nginx 等)
# 注意: 此配置仅在 Docker 容器内部使用，不要在宿主机直接使用

# ===========================================
# 数据库配置
# ===========================================
# PostgreSQL - 使用 Docker 服务名
POSTGRES_USER=scholarai
POSTGRES_PASSWORD=<GENERATE_SECURE_PASSWORD>
POSTGRES_DB=scholarai

DB_USER=scholarai
DB_PASSWORD=<GENERATE_SECURE_PASSWORD>
DB_HOST=postgres
DB_PORT=5432
DB_NAME=scholarai

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis - 使用 Docker 服务名
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Celery (使用 Redis 不同 DB)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===========================================
# Neo4j 配置
# ===========================================
# 容器内禁用 Neo4j (Phase 27+ 后端统一，Neo4j 暂不使用)
NEO4J_DISABLED=true

# 如需启用 Neo4j，取消注释以下配置:
# NEO4J_HOST=neo4j
# NEO4J_PORT=7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=<GENERATE_SECURE_PASSWORD>
# NEO4J_URI=bolt://${NEO4J_HOST}:${NEO4J_PORT}
# NEO4J_AUTH=neo4j/${NEO4J_PASSWORD}

# ===========================================
# Milvus Vector Database (多模态向量存储)
# ===========================================
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION_IMAGES=paper_images
MILVUS_COLLECTION_TABLES=paper_tables

# ===========================================
# Embedding 配置
# ===========================================
# 可选值:
#   - auto: 自动选择 (推荐) - 英文短论文用SPECTER2，其他用BGE-M3
#   - bge-m3: BGE-M3 (多语言，长文档)
#   - specter2: SPECTER 2 (英文论文专用)
#   - sentence-transformers: 传统模型

# 智能自动选择 (推荐)
EMBEDDING_BACKEND=auto

# BGE-M3 配置 (多语言，长文档)
EMBEDDING_MODEL=BAAI/bge-m3

# SPECTER 2 配置 (英文论文专用)
SPECTER2_ADAPTER=proximity  # proximity, adhoc_query, classification, regression

# ===========================================
# AI 服务配置
# ===========================================
# OpenAI API Key (用于LLM和Embedding)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (可选，用于Claude模型)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Zhipu API Key (可选，智谱 GLM 模型)
ZHIPU_API_KEY=your-zhipu-api-key-here

# AI服务URL (容器内通信)
AI_SERVICE_URL=http://backend:8000

# ===========================================
# API 服务配置 (Python FastAPI)
# ===========================================
ENVIRONMENT=development
FRONTEND_URL=http://nginx

# JWT 密钥 (生产环境请更换)
JWT_SECRET=your-jwt-secret-key-change-in-production

# JWT RSA 密钥 (可选，用于 RS256 算法)
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# ===========================================
# 存储配置
# ===========================================
# 本地存储 (容器内)
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=/app/uploads

# S3 存储 (可选)
S3_BUCKET=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===========================================
# 前端配置
# ===========================================
VITE_API_URL=http://nginx

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=info

# ===========================================
# 模型离线模式 (容器内预加载模型)
# ===========================================
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1