# ScholarAI 开发环境配置

# ===========================================
# 数据库配置
# ===========================================
POSTGRES_USER=scholarai
POSTGRES_PASSWORD=scholarai123
POSTGRES_DB=scholarai
DATABASE_URL=postgresql://scholarai:scholarai123@localhost:5432/scholarai

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# Neo4j 配置
NEO4J_AUTH=neo4j/scholarai123

# ===========================================
# Milvus Vector Database (多模态向量存储)
# ===========================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_IMAGES=paper_images
MILVUS_COLLECTION_TABLES=paper_tables

# ===========================================
# Embedding 配置
# ===========================================
# 可选值:
#   - auto: 自动选择 (推荐) - 英文短论文用SPECTER2，其他用BGE-M3
#   - bge-m3: BGE-M3 (多语言，长文档)
#   - specter2: SPECTER 2 (英文论文专用)
#   - sentence-transformers: 传统模型

# 智能自动选择 (推荐)
EMBEDDING_BACKEND=auto

# BGE-M3 配置 (多语言，长文档)
EMBEDDING_MODEL=BAAI/bge-m3

# SPECTER 2 配置 (英文论文专用)
SPECTER2_ADAPTER=proximity  # proximity, adhoc_query, classification, regression

# 备选: Sentence Transformers (768维)
# EMBEDDING_BACKEND=sentence-transformers
# EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ===========================================
# AI 服务配置
# ===========================================
# OpenAI API Key (用于LLM和Embedding)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (可选，用于Claude模型)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI服务URL (Docker内网通信)
AI_SERVICE_URL=http://localhost:8000

# ===========================================
# Node.js API 服务配置
# ===========================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# JWT 密钥 (生产环境请更换)
JWT_SECRET=your-jwt-secret-key-change-in-production

# ===========================================
# 前端配置
# ===========================================
VITE_API_URL=http://localhost:4000

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=info
