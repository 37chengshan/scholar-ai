# ScholarAI 开发环境配置

# ===========================================
# 数据库配置
# ===========================================
POSTGRES_USER=scholarai
POSTGRES_PASSWORD=scholarai123
POSTGRES_DB=scholarai
DATABASE_URL=postgresql://scholarai:scholarai123@localhost:5432/scholarai

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# Neo4j 配置
NEO4J_AUTH=neo4j/scholarai123

# ===========================================
# Milvus Vector Database (多模态向量存储)
# ===========================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_IMAGES=paper_images
MILVUS_COLLECTION_TABLES=paper_tables

# ===========================================
# AI 服务配置
# ===========================================
# OpenAI API Key (用于LLM和Embedding)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (可选，用于Claude模型)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI服务URL (Docker内网通信)
AI_SERVICE_URL=http://localhost:8000

# ===========================================
# Node.js API 服务配置
# ===========================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# JWT 密钥 (生产环境请更换)
JWT_SECRET=your-jwt-secret-key-change-in-production

# ===========================================
# 前端配置
# ===========================================
VITE_API_URL=http://localhost:4000

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=info
