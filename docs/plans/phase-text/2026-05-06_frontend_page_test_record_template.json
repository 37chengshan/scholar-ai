{
  "schema_version": "1.0",
  "document_type": "frontend_page_test_record_template",
  "purpose": "Machine-readable per-page test record template for ScholarAI frontend. Structure only. Fill results later.",
  "scope": {
    "app": "ScholarAI web",
    "source_of_truth": [
      "apps/web/src/app/routes.tsx",
      "docs/plans/phase-text/2026-05-04_frontend_full_test_plan.md"
    ],
    "coverage_goal": "Every top-level page is one block. Each block defines how to record UI, content, copy, interaction, integration, and issue findings."
  },
  "fill_rules": {
    "page_block_rule": "Each top-level page must keep one stable object in pages[]. Do not split a page into multiple top-level records.",
    "subpage_rule": "Use sections[] for tabs, side panels, drawers, right rails, modal flows, and route-local subviews.",
    "execution_rule": "Fill only from code-backed or browser-backed verification. Do not mark pass from expectation only.",
    "status_enum": [
      "not-tested",
      "passed",
      "partial",
      "failed",
      "blocked",
      "not-applicable"
    ],
    "severity_enum": [
      "blocker",
      "high",
      "medium",
      "low"
    ],
    "owner_enum": [
      "frontend",
      "backend",
      "data",
      "tooling",
      "unknown"
    ],
    "evidence_rule": "Every non-not-tested result should include at least one evidence item such as screenshot path, console error, network request, API response summary, or test command.",
    "copy_review_rule": "If any placeholder, test copy, broken Chinese/English mix, or misleading runtime copy is found, log it under issues[] even if the flow still works.",
    "ui_review_rule": "Record layout breakage, font mismatch, overflow, spacing inconsistency, occlusion, or visual hierarchy issues under ui_checks and issues[].",
    "update_rule": "Do not rename route_key once created. Append new issues and update status fields over time."
  },
  "shared_fields_template": {
    "overall_status": "not-tested",
    "last_tested_at": "",
    "tester": "",
    "viewport": "",
    "account_state": "",
    "summary": "",
    "evidence": [],
    "issues": [
      {
        "id": "",
        "title": "",
        "status": "not-tested",
        "severity": "medium",
        "owner": "unknown",
        "symptom": "",
        "expected": "",
        "actual": "",
        "repro_steps": [],
        "evidence": [],
        "notes": ""
      }
    ]
  },
