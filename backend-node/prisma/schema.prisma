generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model annotations {
  id          String   @id
  paperId     String
  userId      String
  type        String
  page_number Int
  position    Json
  content     String?
  color       String   @default("#FFEB3B")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  papers      papers   @relation(fields: [paperId], references: [id], onDelete: Cascade)
  users       users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([paperId, page_number])
  @@index([userId])
}

model configs {
  id          String   @id
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

model knowledge_maps {
  id          String   @id
  name        String
  description String?
  domain      String?
  nodeCount   Int      @default(0)
  edgeCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  users       users    @relation("UserKnowledgeMaps", fields: [userId], references: [id], onDelete: Cascade)
}

model paper_chunks {
  id        String   @id
  content   String
  section   String?
  pageStart Int?
  pageEnd   Int?
  isTable   Boolean  @default(false)
  isFigure  Boolean  @default(false)
  isFormula Boolean  @default(false)
  createdAt DateTime @default(now())
  paperId   String
  papers    papers   @relation("PaperChunks", fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model papers {
  id              String             @id
  title           String
  authors         String[]
  year            Int?
  abstract        String?
  doi             String?
  arxivId         String?
  pdfUrl          String?
  pdfPath         String?
  content         String?
  imradJson       Json?
  status          String             @default("pending")
  fileSize        Int?
  pageCount       Int?
  keywords        String[]
  venue           String?
  citations       Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  userId          String
  storageKey      String?            @map("storage_key")
  readingNotes    String?            @map("reading_notes")
  notesVersion    Int                @default(0) @map("notes_version")
  starred         Boolean            @default(false)
  projectId       String?
  batchId         String?            @map("batch_id")
  uploadStatus    String?            @default("pending") @map("upload_status")
  uploadProgress  Int?               @default(0) @map("upload_progress")
  uploadedAt      DateTime?          @map("uploaded_at")
  annotations     annotations[]
  paperChunks     paper_chunks[]     @relation("PaperChunks")
  projects        projects?          @relation(fields: [projectId], references: [id])
  users           users              @relation(fields: [userId], references: [id], onDelete: Cascade)
  processingTasks processing_tasks?  @relation("PaperProcessingTasks")
  readingProgress reading_progress[] @relation("PaperReadingProgress")
  queries         queries[]          @relation("QueryPapers")
  batch           paper_batches?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  uploadHistory   UploadHistory[]

  @@index([userId])
  @@index([starred])
  @@index([userId, starred])
  @@index([batchId])
  @@unique([userId, title], name: "unique_user_title")
}

model permissions {
  id       String  @id
  resource String
  action   String
  roles    roles[] @relation("PermissionToRole")

  @@unique([resource, action])
}

model processing_tasks {
  id           String    @id
  paperId      String    @unique @map("paper_id")
  status       String    @default("pending")
  storageKey   String    @map("storage_key")
  errorMessage String?   @map("error_message")
  attempts     Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  completedAt  DateTime? @map("completed_at")
  papers       papers    @relation("PaperProcessingTasks", fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([status])
}

model paper_batches {
  id            String   @id
  userId        String
  totalFiles    Int      @map("total_files")
  uploadedCount Int      @default(0) @map("uploaded_count")
  status        String   @default("uploading")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  papers        papers[]
  users         users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model projects {
  id        String   @id
  userId    String
  name      String
  color     String   @default("#3B82F6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  papers    papers[]
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model queries {
  id         String   @id
  question   String
  answer     String?
  sources    Json?
  queryType  String   @default("single")
  status     String   @default("pending")
  durationMs Int?
  createdAt  DateTime @default(now())
  userId     String
  paperIds   String[]
  users      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  papers     papers[] @relation("QueryPapers")

  @@index([createdAt])
  @@index([userId])
}

model reading_progress {
  id          String   @id
  paperId     String
  userId      String
  currentPage Int      @default(1) @map("current_page")
  totalPages  Int?     @map("total_pages")
  lastReadAt  DateTime @default(now()) @map("last_read_at")
  papers      papers   @relation("PaperReadingProgress", fields: [paperId], references: [id], onDelete: Cascade)
  users       users    @relation("UserReadingProgress", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([paperId, userId])
  @@index([lastReadAt])
  @@index([userId])
}

model refresh_tokens {
  id        String   @id
  tokenHash String   @unique @map("token")
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  users     users    @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)
}

model roles {
  id          String        @id
  name        String        @unique
  description String?
  user_roles  user_roles[]
  permissions permissions[] @relation("PermissionToRole")
}

model user_roles {
  id     String @id
  userId String
  roleId String
  roles  roles  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  users  users  @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model notes {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String   @db.Text
  tags      String[]
  paperIds  String[] @map("paper_ids")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notes")
}

model sessions {
  id             String   @id
  userId         String   @map("user_id")
  title          String?
  status         String   @default("active")
  metadata       Json     @default("{}")
  messageCount   Int      @default(0) @map("message_count")
  toolCallCount  Int      @default(0) @map("tool_call_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  expiresAt      DateTime @map("expires_at")
  user           users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  tool         String
  riskLevel    String    @map("risk_level")
  params       Json?
  result       String?
  tokensUsed   Int?      @map("tokens_used")
  costCny      Float?    @map("cost_cny")
  executionMs  Int?      @map("execution_ms")
  ipAddress    String?   @map("ip_address")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([riskLevel])
  @@map("audit_logs")
}

model user_memories {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  content     String
  memoryType  String   @map("memory_type")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_memories")
}

model UploadHistory {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  paperId        String?   @map("paper_id")
  filename       String
  status         String    @default("PROCESSING")
  chunksCount    Int?      @map("chunks_count")
  llmTokens      Int?      @map("llm_tokens")
  pageCount      Int?      @map("page_count")
  imageCount     Int?      @map("image_count")
  tableCount     Int?      @map("table_count")
  errorMessage   String?   @map("error_message")
  processingTime Int?      @map("processing_time")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paper          papers?   @relation(fields: [paperId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("upload_history")
}

model users {
  id              String             @id
  email           String             @unique
  name            String
  passwordHash    String             @map("password_hash")
  emailVerified   Boolean            @default(false) @map("email_verified")
  avatar          String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  annotations     annotations[]
  auditLogs       AuditLog[]
  knowledgeMaps   knowledge_maps[]   @relation("UserKnowledgeMaps")
  notes           notes[]
  papers          papers[]
  paperBatches    paper_batches[]
  projects        projects[]
  queries         queries[]
  readingProgress reading_progress[] @relation("UserReadingProgress")
  refreshTokens   refresh_tokens[]   @relation("UserRefreshTokens")
  sessions        sessions[]
  uploadHistory   UploadHistory[]
  userMemories    user_memories[]
  userRoles       user_roles[]       @relation("UserRoles")
}
