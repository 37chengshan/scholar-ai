# ==========================================
# ScholarAI Unified Backend Configuration
# ==========================================
# Complete environment configuration for the unified FastAPI backend.
# Copy this file to .env and configure for your environment.
#
# IMPORTANT: Mark sensitive values with your actual secrets in production.
# NEVER commit .env files with real secrets to the repository.
# ==========================================

# ==========================================
# Application Configuration
# ==========================================
# Basic application settings for server startup and logging.

APP_NAME=ScholarAI API
DEBUG=false
LOG_LEVEL=info
PORT=8000
ENVIRONMENT=development

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL connection URL with async driver support.
# Format: postgresql://user:password@host:port/database

DATABASE_URL=postgresql://scholarai:scholarai123@localhost:5432/scholarai

# ==========================================
# Redis Configuration (Session + Cache)
# ==========================================
# Redis for session storage, caching, and rate limiting.
# Format: redis://host:port/database_number

REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# Neo4j Configuration (Graph Database)
# ==========================================
# Neo4j for knowledge graph storage and entity relationships.
# Format: bolt://host:port

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=scholarai123

# ==========================================
# Milvus Configuration (Vector Database)
# ==========================================
# Milvus for vector storage (embeddings for RAG).
# Host and port for Milvus standalone deployment.

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_IMAGES=paper_images
MILVUS_COLLECTION_TABLES=paper_tables
MILVUS_COLLECTION_CONTENTS=paper_contents
MILVUS_COLLECTION_CONTENTS_V2=paper_contents_v2
MILVUS_POOL_SIZE=10
MILVUS_TIMEOUT=10

# ==========================================
# Authentication Configuration
# ==========================================
# JWT settings for OAuth 2.0 + Cookie-based authentication.
# IMPORTANT: JWT_SECRET must be at least 32 characters in production!

JWT_SECRET=your-secret-key-here-min-32-chars-long-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Internal service JWT (RS256) - for service-to-service auth
JWT_INTERNAL_PUBLIC_KEY=
JWT_INTERNAL_PUBLIC_KEY_FILE=

# ==========================================
# CORS Configuration
# ==========================================
# Allowed origins for CORS (frontend URLs).
# IMPORTANT: In production, specify exact origins, NOT ["*"]!
# Credentials=True requires specific origins (browser security).

# Development: ALLOWED_HOSTS=["http://localhost:5173","http://localhost:3000"]
# Production: ALLOWED_HOSTS=["https://app.yourdomain.com"]
ALLOWED_HOSTS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# ==========================================
# File Upload Configuration
# ==========================================
# Maximum file size and upload directory for PDF uploads.
# MAX_FILE_SIZE: 50MB = 52428800 bytes

MAX_FILE_SIZE=52428800
UPLOAD_DIR=/app/uploads

# ==========================================
# S3/MinIO Storage Configuration
# ==========================================
# Object storage for PDF files. Use local storage for development.

USE_LOCAL_STORAGE=true
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=scholarai
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Legacy OSS configuration (backward compatibility)
OSS_ENDPOINT=local
LOCAL_STORAGE_PATH=/app/uploads

# ==========================================
# AI Service Configuration
# ==========================================
# Zhipu AI API keys for LLM and vision models.
# IMPORTANT: Set ZHIPU_API_KEY for AI features!

ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL_VISION=glm-4v
ZHIPU_MODEL_TEXT=glm-4-flash
ZHIPU_MAX_TOKENS=150
ZHIPU_TEMPERATURE=0.3

# LLM Configuration
LLM_MODEL=glm-4.5-air
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=5
DEFAULT_MODEL=gpt-4o-mini

# ==========================================
# Embedding Model Configuration
# ==========================================
# Qwen3-VL embedding model for vector generation.
# EMBEDDING_DEVICE: auto|cpu|cuda|mps (auto-detect GPU)

EMBEDDING_MODEL=qwen3-vl-2b
EMBEDDING_QUANTIZATION=int4
EMBEDDING_DIMENSION=2048
EMBEDDING_DEVICE=auto

# Reranker Model
RERANKER_MODEL=bge-reranker
RERANKER_QUANTIZATION=fp16

# Local Model Paths
QWEN3VL_EMBEDDING_MODEL_PATH=./Qwen/Qwen3-VL-Embedding-2B
QWEN3VL_RERANKER_MODEL_PATH=./Qwen/Qwen3-VL-Reranker-2B

# ==========================================
# RAG Configuration
# ==========================================
# Chunk settings for document processing.

CHUNK_SIZE=500
CHUNK_OVERLAP=100
CHUNK_MIN_SIZE=100
CHUNK_MAX_SIZE=600
CHUNK_ADAPTIVE_ENABLED=true
CHUNK_QUALITY_THRESHOLD=0.7
TOP_K_RETRIEVAL=10

# ==========================================
# External API Configuration
# ==========================================
# API keys for external services (optional features).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
S2_API_KEY=

# Semantic Scholar Cache TTLs (seconds)
S2_CACHE_TTL=86400
S2_PAPER_TTL=604800
S2_CITATION_TTL=2592000

# ==========================================
# HuggingFace Offline Mode
# ==========================================
# Use cached models without network access.
# Set to 0 to download models on first use.

HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ==========================================
# Rate Limiting (Optional)
# ==========================================
# Request rate limiting configuration.
# Uncomment to enable rate limiting.

# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=60